{
  "version": "independent",
  "packages": ["packages/@atjson/*"],
  "command": {
    "publish": {
      "exact": true,
      "conventionalCommits": true,
      "message": "chore(release): publish"
    },
    "bootstrap": {
      "hoist": true,
      "npmClientArgs": ["--no-package-lock"]
    }
  },
  "$schema": "node_modules/lerna/schemas/lerna-schema.json"
}
